DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/instagram_dm_assistant
REDIS_URL=redis://redis:6379/0
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
QDRANT_URL=http://qdrant:6333
# LLM provider selection. Set LLM_MODE=live plus the matching API key below to get
# real intent/slot/product confidence (mock mode always returns 0.50, which forces handoff).
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.avalai.ir/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
APP_ENV=local
LOG_LEVEL=INFO
JWT_SECRET_KEY=change-me-in-local-development
TOKEN_ENCRYPTION_KEY=local-dev-token-encryption-key-32b!
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=local-instagram-verify-token
INSTAGRAM_APP_SECRET=
ENABLE_REAL_INSTAGRAM_SEND=false
CONVERSATION_LOCK_TTL_SECONDS=120
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN_PER_MINUTE=10
RATE_LIMIT_WEBHOOK_PER_MINUTE=120
RATE_LIMIT_OUTBOUND_MESSAGE_PER_MINUTE=30
RABBITMQ_MAX_RETRIES=3
RABBITMQ_RETRY_DELAY_MS=30000
BACKGROUND_JOB_INTERVAL_SECONDS=60
EMBEDDING_REFRESH_BATCH_SIZE=50
DEFAULT_MODEL_VERSION=gpt-4o-mini
DEFAULT_PROMPT_VERSION=trust-layer-v1
DEFAULT_POLICY_VERSION=trust-layer-v1
CORS_ORIGINS=["http://localhost:5173","http://frontend:5173"]
LLM_MODE=mock
WEBHOOK_SIGNATURE_BYPASS=false
TRL_LIVE_LLM_ENABLED=false
TRL_AVERAGE_PROCESSING_TIME_MS_THRESHOLD=2000
TRL_P95_PROCESSING_TIME_MS_THRESHOLD=5000
# Windows Hyper-V often blocks 8000; use 8800 locally (8000 is fine on Linux/macOS).
BACKEND_HOST_PORT=8800
VITE_API_BASE_URL=http://localhost:8800
FRONTEND_HOST_PORT=5173
LANDING_PORT=5174
LANDING_HOST_PORT=5174
VITE_FRONTEND_URL=http://localhost:5173
VITE_LANDING_URL=http://localhost:5174
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=changeme123
DEFAULT_ADMIN_NAME=Platform Admin

API_PUBLIC_BASE_URL=https://api.yourdomain.com

# DEVELOPMENT ONLY — do not use these defaults in staging/production.
# Production/staging requires strong JWT_SECRET_KEY (32+ chars), TOKEN_ENCRYPTION_KEY,
# INSTAGRAM_APP_SECRET, non-default INSTAGRAM_WEBHOOK_VERIFY_TOKEN, explicit HTTPS CORS_ORIGINS,
# and WEBHOOK_SIGNATURE_BYPASS=false.

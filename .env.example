# Modira — AI Social Media Admin OS
APP_ENV=local
PUBLIC_API_BASE_URL=http://localhost:8800
FRONTEND_BASE_URL=http://localhost:5173
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/modira
REDIS_URL=redis://redis:6379/0
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
QDRANT_URL=http://qdrant:6333

# Security: replace all development values before staging or production.
JWT_SECRET_KEY=change-me-in-local-development
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
# Set true behind HTTPS in staging/production. Leave blank to derive from APP_ENV.
# AUTH_COOKIE_SECURE=true
CSRF_COOKIE_NAME=modira_csrf
TOKEN_ENCRYPTION_KEY=local-dev-token-encryption-key-32b!
WEBHOOK_INTERNAL_SECRET=local-dev-webhook-verification-secret
OAUTH_STATE_SECRET=local-dev-oauth-state-secret
CORS_ORIGINS=["http://localhost:5173","http://frontend:5173"]
CORS_ALLOW_CREDENTIALS=true
WEBHOOK_SIGNATURE_BYPASS=false

# Global Meta application settings. Shop-level channel tokens are stored per shop,
# encrypted in the database, and must not be configured globally here.
META_APP_ID=
META_APP_SECRET=
META_GRAPH_API_VERSION=v20.0
META_GRAPH_API_BASE_URL=https://graph.facebook.com
META_OAUTH_SCOPES=["instagram_basic","instagram_manage_messages","pages_show_list","pages_read_engagement","pages_manage_metadata","business_management"]
META_OAUTH_REDIRECT_PATH=/api/v1/channels/instagram/oauth/callback
META_PRIVACY_POLICY_URL=

# Channel system
ENABLED_CHANNEL_PROVIDERS=instagram,whatsapp,telegram,bale,rubika
ENABLE_REAL_PROVIDER_SEND=false
# allow | warn | reject — text-hash fallback when idempotency_key is omitted (simulation/test/local only)
OUTBOUND_IDEMPOTENCY_FALLBACK_MODE=allow

# Telegram platform manager bot (managed bot provisioning)
TELEGRAM_MANAGER_BOT_TOKEN=
TELEGRAM_MANAGER_BOT_USERNAME=
TELEGRAM_MANAGER_BOT_ID=
TELEGRAM_MANAGER_WEBHOOK_SECRET=

# Channel-generic inbound queues
RABBITMQ_QUEUE_MESSAGE_RECEIVED=channel.message.received
RABBITMQ_QUEUE_RETRY=channel.message.received.retry
RABBITMQ_QUEUE_DLQ=channel.message.received.dlq
RABBITMQ_QUEUE_PAYMENT_CALLBACKS=payment_callbacks
RABBITMQ_QUEUE_RESERVATION_EXPIRY=reservation_expiry
RABBITMQ_QUEUE_ORDER_COMPENSATION=order_compensation
RABBITMQ_QUEUE_OPERATOR_ALERTS=operator_alerts
RABBITMQ_QUEUE_DEAD_LETTER=dead_letter
RABBITMQ_MAX_RETRIES=3
RABBITMQ_RETRY_DELAY_MS=30000

LOG_LEVEL=INFO
CONVERSATION_LOCK_TTL_SECONDS=120
RATE_LIMIT_ENABLED=true
# Only trust forwarding headers from these proxy CIDRs. Leave empty when not behind a trusted proxy.
TRUSTED_PROXY_CIDRS=[]
RATE_LIMIT_LOGIN_PER_MINUTE=10
RATE_LIMIT_WEBHOOK_PER_MINUTE=120
RATE_LIMIT_OUTBOUND_MESSAGE_PER_MINUTE=30
BACKGROUND_JOB_INTERVAL_SECONDS=60
EMBEDDING_REFRESH_BATCH_SIZE=50
RESERVATION_DEFAULT_TTL_SECONDS=1800
ORDER_EXPIRATION_MINUTES=30

# Qdrant collections and catalog tuning
QDRANT_COLLECTION_NAME=products
QDRANT_VARIANTS_COLLECTION_NAME=variants
CATALOG_IMPORT_BATCH_SIZE=25
CATALOG_REINDEX_BATCH_SIZE=50
RESOLVER_DEFAULT_HIGH_THRESHOLD=0.85
RESOLVER_DEFAULT_MEDIUM_THRESHOLD=0.55
HYBRID_FUSION_STRATEGY=rrf
HYBRID_RRF_K=60

# Agent confidence thresholds
AGENT_INTENT_CONFIDENCE_THRESHOLD=0.65
AGENT_SLOTS_CONFIDENCE_THRESHOLD=0.60
AGENT_MAX_FAILURES=2

# LLM provider selection
LLM_MODE=mock
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.avalai.ir/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
DEFAULT_MODEL_VERSION=gpt-4o-mini
DEFAULT_PROMPT_VERSION=trust-layer-v1
DEFAULT_POLICY_VERSION=trust-layer-v1

# TRL validation thresholds (staging)
TRL_LIVE_LLM_ENABLED=false
TRL_AVERAGE_PROCESSING_TIME_MS_THRESHOLD=2000
TRL_P95_PROCESSING_TIME_MS_THRESHOLD=5000

# Docker Compose infrastructure (postgres/rabbitmq credentials)
POSTGRES_DB=modira
POSTGRES_APP_USER=postgres
POSTGRES_APP_PASSWORD=postgres
POSTGRES_SUPERUSER_PASSWORD=postgres
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest

# Local service ports and bootstrap admin
BACKEND_HOST_PORT=8800
BACKEND_BIND_IP=127.0.0.1
VITE_API_BASE_URL=http://localhost:8800
VITE_PUBLIC_API_BASE_URL=http://localhost:8800
FRONTEND_HOST_PORT=5173
FRONTEND_BIND_IP=127.0.0.1
LANDING_PORT=5174
LANDING_HOST_PORT=5174
LANDING_BIND_IP=127.0.0.1
VITE_FRONTEND_URL=http://localhost:5173
VITE_LANDING_URL=http://localhost:5174
VITE_DEFAULT_ADMIN_EMAIL=admin@example.com
VITE_DEFAULT_ADMIN_PASSWORD=changeme123
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=changeme123
DEFAULT_ADMIN_NAME=Platform Admin

# Playwright E2E (optional; not used by docker compose)
E2E_BASE_URL=http://localhost:5173
E2E_WITH_AUTH=
E2E_EMAIL=admin@example.com
E2E_PASSWORD=password123

# CI / pytest overrides (optional; defaults derived from DATABASE_URL / REDIS_URL)
# TEST_DATABASE_URL=
# TEST_REDIS_URL=

# Modira — AI Social Media Admin OS
APP_ENV=local
PUBLIC_API_BASE_URL=http://localhost:8800
FRONTEND_BASE_URL=http://localhost:5173
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/modira
REDIS_URL=redis://redis:6379/0
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
QDRANT_URL=http://qdrant:6333

# Security: replace all development values before staging or production.
JWT_SECRET_KEY=change-me-in-local-development
TOKEN_ENCRYPTION_KEY=local-dev-token-encryption-key-32b!
WEBHOOK_INTERNAL_SECRET=local-dev-webhook-verification-secret
OAUTH_STATE_SECRET=local-dev-oauth-state-secret
CORS_ORIGINS=["http://localhost:5173","http://frontend:5173"]
WEBHOOK_SIGNATURE_BYPASS=false

# Global Meta application settings. Shop-level channel tokens are stored per shop,
# encrypted in the database, and must not be configured globally here.
META_APP_ID=
META_APP_SECRET=
META_GRAPH_API_VERSION=v20.0
META_GRAPH_API_BASE_URL=https://graph.facebook.com

# Channel system
ENABLED_CHANNEL_PROVIDERS=instagram,whatsapp,telegram,bale,rubika
ENABLE_REAL_PROVIDER_SEND=false

# Channel-generic inbound queues
RABBITMQ_QUEUE_MESSAGE_RECEIVED=channel.message.received
RABBITMQ_QUEUE_RETRY=channel.message.received.retry
RABBITMQ_QUEUE_DLQ=channel.message.received.dlq
RABBITMQ_MAX_RETRIES=3
RABBITMQ_RETRY_DELAY_MS=30000

LOG_LEVEL=INFO
CONVERSATION_LOCK_TTL_SECONDS=120
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN_PER_MINUTE=10
RATE_LIMIT_WEBHOOK_PER_MINUTE=120
RATE_LIMIT_OUTBOUND_MESSAGE_PER_MINUTE=30
BACKGROUND_JOB_INTERVAL_SECONDS=60
EMBEDDING_REFRESH_BATCH_SIZE=50

# LLM provider selection
LLM_MODE=mock
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.avalai.ir/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
DEFAULT_MODEL_VERSION=gpt-4o-mini
DEFAULT_PROMPT_VERSION=trust-layer-v1
DEFAULT_POLICY_VERSION=trust-layer-v1

# Local service ports and bootstrap admin
BACKEND_HOST_PORT=8800
VITE_API_BASE_URL=http://localhost:8800
FRONTEND_HOST_PORT=5173
LANDING_PORT=5174
LANDING_HOST_PORT=5174
VITE_FRONTEND_URL=http://localhost:5173
VITE_LANDING_URL=http://localhost:5174
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=changeme123
DEFAULT_ADMIN_NAME=Platform Admin

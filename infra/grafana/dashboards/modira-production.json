{
  "title": "Modira SOC-OS Production",
  "schemaVersion": 39,
  "panels": [
    {"type": "timeseries", "title": "Event throughput", "targets": [{"expr": "sum(rate(soc_events_published_total[5m])) by (topic)"}]},
    {"type": "timeseries", "title": "Per-tenant load", "targets": [{"expr": "sum(rate(soc_tenant_events_total[5m])) by (tenant_id)"}]},
    {"type": "timeseries", "title": "Queue lag per topic", "targets": [{"expr": "sum(kafka_consumergroup_lag) by (topic,consumergroup)"}]},
    {"type": "timeseries", "title": "Automation success rate", "targets": [{"expr": "sum(rate(soc_automation_success_total[5m])) / sum(rate(soc_scenario_routed_total[5m]))"}]},
    {"type": "timeseries", "title": "LLM fallback rate", "targets": [{"expr": "sum(rate(soc_llm_fallback_total[5m])) by (tenant_id)"}]},
    {"type": "timeseries", "title": "Worker failures", "targets": [{"expr": "sum(rate(soc_worker_failures_total[5m])) by (worker_type)"}]},
    {"type": "timeseries", "title": "API p95/p99 latency", "targets": [{"expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le,path))"}, {"expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[5m])) by (le,path))"}]}
  ]
}
